  <Capability Min="190" Max="255">Full ON</Capability>
 </Channel>
 <Channel Name="Programs">
  <Group Byte="0">Effect</Group>
  <Capability Min="0" Max="9">No function</Capability>
  <Capability Min="10" Max="39">Auto program 1, with increasing speed</Capability>
