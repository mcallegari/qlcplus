  <Capability Min="10" Max="129" Preset="RotationClockwiseSlowToFast">Clockwise rotation</Capability>
  <Capability Min="130" Max="255" Preset="RotationCounterClockwiseSlowToFast">Counterclockwise rotation</Capability>
 </Channel>
 <Channel Name="Led Bar - Strobe">
  <Group Byte="0">Shutter</Group>
  <Capability Min="0" Max="9">No function</Capability>
  <Capability Min="10" Max="255">Strobe (Slow to fast)</Capability>
 </Channel>
