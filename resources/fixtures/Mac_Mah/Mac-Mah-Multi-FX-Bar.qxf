 </Channel>
 <Channel Name="Laser - Color">
  <Group Byte="0">Colour</Group>
  <Capability Min="0" Max="9">No function</Capability>
  <Capability Min="10" Max="59" Preset="ColorMacro" Res1="#ff0000">Laser red</Capability>
  <Capability Min="60" Max="109" Preset="ColorMacro" Res1="#00ff00">Laser green</Capability>
  <Capability Min="110" Max="159" Preset="ColorDoubleMacro" Res1="#ff0000" Res2="#00ff00">Laser red + green</Capability>
  <Capability Min="160" Max="255" Preset="SlowToFast">Laser R+G effect group（speed lowhigh）</Capability>
 </Channel>
 <Channel Name="Laser - Rotation">
